BETTER_AUTH_SECRET=               # secreto largo aleatorio (openssl rand -base64 32)
BETTER_AUTH_URL=                  # ej. https://chuterfc.com (local: http://localhost:4321)
BLOB_READ_WRITE_TOKEN=            # Vercel Blob (imagen de la parte central de entrenos)

# Seed del admin raíz (Camilo) — solo para scripts/seed-admin.mjs
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=
SEED_ADMIN_NAME=
