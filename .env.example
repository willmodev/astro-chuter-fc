PUBLIC_SITE_URL=

# Correo del formulario (Resend) — server-only, NUNCA con prefijo PUBLIC_
RESEND_API_KEY=
CONTACT_EMAIL_FROM=
CONTACT_EMAIL_TO=

# Módulo admin — base de datos y auth (server-only, NUNCA con prefijo PUBLIC_)
