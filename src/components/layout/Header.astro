---
import Logo from '@/components/layout/Logo.astro';
import Nav from '@/components/layout/Nav.astro';
import MobileMenu from '@/components/interactive/MobileMenu';
import BrandButton from '@/components/layout/BrandButton.astro';
import { WA_HERO } from '@/lib/whatsapp';
---

<header
  class="sticky top-0 z-30 w-full border-b border-neutral-200/60 bg-white/95 backdrop-blur-md"
>
  <div class="mx-auto flex h-16 max-w-7xl items-center justify-between px-4 md:px-6 lg:px-8">
    <Logo />

    <Nav class="hidden lg:flex" />

    <div class="hidden lg:block">
      <BrandButton href={WA_HERO} variant="cta-gold" size="md" target="_blank">
        ¡Inscripción Gratis!
      </BrandButton>
    </div>

    <div class="lg:hidden">
      <MobileMenu client:load />
    </div>
  </div>
</header>
