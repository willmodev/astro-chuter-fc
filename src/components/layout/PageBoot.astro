---
/**
 * PageBoot — overlay de boot que se muestra solo en la primera carga de la sesión.
 * Logo "CHUTER" se pinta con stroke-dashoffset (path drawing).
 * Después del fade-out (~1.6s total) queda totalmente removido del DOM via setTimeout.
 *
 * Razón: dar un primer frame "cinematográfico" al cliente cuando abre el sitio
 * por primera vez sin penalizar las navegaciones internas o reloads.
 */
---

<div id="page-boot" class="page-boot" aria-hidden="true">
    <svg
        class="page-boot-logo h-16 w-auto md:h-24"
        viewBox="0 0 360 80"
        fill="none"
        stroke="#F5C842"
        stroke-width="2.5"
        stroke-linecap="round"
        stroke-linejoin="round"
    >
        <!-- C -->
        <path pathLength="1" d="M55 18 Q 25 18, 25 40 Q 25 62, 55 62" />
        <!-- H -->
        <path pathLength="1" d="M75 18 V 62 M75 40 H 110 M110 18 V 62" />
        <!-- U -->
        <path pathLength="1" d="M125 18 V 50 Q 125 62, 145 62 Q 165 62, 165 50 V 18" />
        <!-- T -->
        <path pathLength="1" d="M180 18 H 215 M197.5 18 V 62" />
        <!-- E -->
        <path pathLength="1" d="M255 18 H 230 V 62 H 255 M230 40 H 250" />
        <!-- R -->
        <path pathLength="1" d="M270 62 V 18 H 295 Q 305 18, 305 30 Q 305 42, 295 42 H 270 M295 42 L 310 62" />
        <!-- · FC -->
        <circle pathLength="1" cx="325" cy="40" r="2.5" fill="#F5C842" />
    </svg>
</div>

<script is:inline>
    (function () {
        try {
            // Si ya bootó en esta sesión, ocultar inmediatamente (cero flash).
            if (sessionStorage.getItem('chuter:booted')) {
                const el = document.getElementById('page-boot');
                if (el) el.remove();
                return;
            }
            sessionStorage.setItem('chuter:booted', '1');
            // Limpiar el overlay del DOM tras la animación (1100ms draw + 500ms fade)
            setTimeout(() => {
                const el = document.getElementById('page-boot');
                if (el) el.remove();
            }, 1700);
        } catch (_) {
            // sessionStorage puede fallar en modo privado; en ese caso dejar que la animación corra.
            setTimeout(() => {
                const el = document.getElementById('page-boot');
                if (el) el.remove();
            }, 1700);
        }
    })();
</script>
