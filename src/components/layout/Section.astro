---
interface Props {
  id?: string;
  class?: string;
  variant?: 'light' | 'dark' | 'navy' | 'white';
}

const { id, class: className = '', variant = 'light' } = Astro.props;

const variantClasses: Record<string, string> = {
  light: 'bg-neutral-50',
  dark: 'bg-neutral-900 text-white',
  navy: 'bg-brand-navy text-white',
  white: 'bg-white',
};
---

<section
  id={id}
  class={`py-16 md:py-24 ${variantClasses[variant]} ${className}`}
>
  <slot />
</section>
