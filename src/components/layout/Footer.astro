---
import Logo from '@/components/layout/Logo.astro';
import { SITE, CONTACT, SCHEDULE, NAV_LINKS } from '@/lib/site';
import { WA_HERO } from '@/lib/whatsapp';

const currentYear = new Date().getFullYear();

const programLinks = [
  { label: 'Categoría Baby', cat: 'Baby' },
  { label: 'Categoría Pony', cat: 'Pony' },
  { label: 'Categoría Benjamín', cat: 'Benjamín' },
  { label: 'Categoría Pre-infantil', cat: 'Pre-infantil' },
  { label: 'Categoría Infantil', cat: 'Infantil' },
];
---

<footer class="bg-neutral-950 text-white" aria-label="Pie de página">
  <div class="mx-auto max-w-7xl px-4 py-14 md:px-6 lg:px-8">
    <div class="grid gap-10 sm:grid-cols-2 lg:grid-cols-4">
      <div class="space-y-4 lg:col-span-1">
        <Logo light />
        <p class="text-sm leading-relaxed text-white/60">
          {SITE.tagline}
        </p>
        <div class="inline-flex items-center gap-2 rounded-full border border-brand-gold/30 bg-brand-gold/10 px-3 py-1.5">
          <svg
            aria-hidden="true"
            width="14"
            height="14"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            class="shrink-0 text-brand-gold"
          >
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" />
          </svg>
          <span class="text-xs font-semibold text-brand-gold">Aval INDER</span>
        </div>
      </div>

      <div>
        <h3 class="mb-4 text-xs font-semibold uppercase tracking-widest text-white/40">
          Contacto
        </h3>
        <ul class="space-y-3 text-sm">
          <li>
            <a
              href={WA_HERO}
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center gap-2 text-white/70 transition-colors hover:text-white focus-visible:outline-2 focus-visible:outline-brand-gold focus-visible:rounded"
            >
              <svg aria-hidden="true" width="14" height="14" viewBox="0 0 24 24" fill="currentColor" class="shrink-0 text-whatsapp">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z" />
              </svg>
              {CONTACT.phoneDisplay}
            </a>
          </li>
          <li>
            <a
              href={CONTACT.instagramUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center gap-2 text-white/70 transition-colors hover:text-white focus-visible:outline-2 focus-visible:outline-brand-gold focus-visible:rounded"
            >
              <svg aria-hidden="true" width="14" height="14" viewBox="0 0 24 24" fill="currentColor" class="shrink-0">
                <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838a6.162 6.162 0 1 0 0 12.324 6.162 6.162 0 0 0 0-12.324zM12 16a4 4 0 1 1 0-8 4 4 0 0 1 0 8zm6.406-11.845a1.44 1.44 0 1 0 0 2.881 1.44 1.44 0 0 0 0-2.881z" />
              </svg>
              {CONTACT.instagramHandle}
            </a>
          </li>
          <li class="text-white/50 text-xs">
            <span>{SCHEDULE.daysHuman}</span>
            <br />
            <span>{SCHEDULE.hoursHuman}</span>
          </li>
        </ul>
      </div>

      <div>
        <h3 class="mb-4 text-xs font-semibold uppercase tracking-widest text-white/40">
          Programas
        </h3>
        <ul class="space-y-2 text-sm">
          {programLinks.map(({ label, cat }) => (
            <li>
              <a
                href={`https://wa.me/${CONTACT.whatsappNumber}?text=${encodeURIComponent(`Hola Chuter FC, quiero inscribir a mi hijo en la categoría ${cat}`)}`}
                target="_blank"
                rel="noopener noreferrer"
                class="text-white/70 transition-colors hover:text-white focus-visible:outline-2 focus-visible:outline-brand-gold focus-visible:rounded"
              >
                {label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <div>
        <h3 class="mb-4 text-xs font-semibold uppercase tracking-widest text-white/40">
          Síguenos
        </h3>
        <a
          href={CONTACT.instagramUrl}
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Seguir a Chuter FC en Instagram"
          class="group inline-flex items-center gap-3 rounded-xl border border-white/10 bg-white/5 px-4 py-3 text-sm text-white/70 transition-all hover:border-white/20 hover:bg-white/10 hover:text-white focus-visible:outline-2 focus-visible:outline-brand-gold focus-visible:outline-offset-2"
        >
          <svg aria-hidden="true" width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838a6.162 6.162 0 1 0 0 12.324 6.162 6.162 0 0 0 0-12.324zM12 16a4 4 0 1 1 0-8 4 4 0 0 1 0 8zm6.406-11.845a1.44 1.44 0 1 0 0 2.881 1.44 1.44 0 0 0 0-2.881z" />
          </svg>
          <span>{CONTACT.instagramHandle}</span>
        </a>
        <p class="mt-4 text-xs leading-relaxed text-white/40">
          Seguinos para ver los entrenamientos, logros y novedades del club.
        </p>
      </div>
    </div>

    <div class="mt-12 flex flex-col items-center justify-between gap-4 border-t border-white/10 pt-8 text-center sm:flex-row sm:text-left">
      <p class="text-xs text-white/30">
        © {currentYear} {SITE.legalName}. Todos los derechos reservados.
      </p>
      <p class="text-xs text-white/20">
        Sitio web desarrollado por
        <a
          href="https://instagram.com/willinton.mora"
          target="_blank"
          rel="noopener noreferrer"
          class="text-white/30 hover:text-white/50 transition-colors"
        >
          Will Mora
        </a>
      </p>
    </div>
  </div>
</footer>
