---
import { MISION, VISION, PRINCIPIOS } from '@/lib/esencia';
---

<section id="esencia" class="relative bg-white py-16 md:py-24">
  <div class="mx-auto max-w-7xl px-4 md:px-6 lg:px-8">
    <!-- Encabezado -->
    <div class="mx-auto max-w-3xl text-center">
      <div class="reveal flex items-center justify-center gap-3 pb-4" style="--idx:0">
        <span class="section-marker text-base italic text-brand-navy">Nº 04</span>
        <span class="inline-block h-px w-10 bg-brand-navy/15" aria-hidden="true"></span>
        <p class="text-[0.7rem] font-bold uppercase tracking-[0.22em] text-brand-gold-deep">Nuestra esencia</p>
      </div>
      <h2 class="reveal font-display text-display leading-[0.95] text-brand-navy-deep" style="--idx:1">Misión, visión y principios.</h2>
      <p class="reveal mx-auto mt-4 max-w-2xl text-base leading-relaxed text-neutral-600 md:text-lg" style="--idx:2">
        Lo que somos, hacia dónde vamos y los valores que guían cada entrenamiento.
      </p>
    </div>

    <!-- Misión / Visión -->
    <div class="mt-12 grid gap-6 lg:grid-cols-2">
      <article class="reveal reveal--from-left relative overflow-hidden rounded-sm border border-brand-navy/10 bg-brand-cream p-7 shadow-sm md:p-9" style="--idx:0">
        <span class="absolute left-0 top-0 h-full w-1.5 bg-brand-gold" aria-hidden="true"></span>
        <div class="flex items-center gap-3">
          <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-full bg-white text-brand-navy ring-1 ring-brand-navy/10">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="6"/><circle cx="12" cy="12" r="2"/>
            </svg>
          </div>
          <div>
            <p class="text-[0.7rem] font-bold uppercase tracking-[0.22em] text-brand-gold-deep">Misión</p>
            <h3 class="font-display text-2xl leading-none tracking-wide text-brand-navy-deep">Por qué existimos</h3>
          </div>
        </div>
        <p class="mt-5 text-[0.95rem] leading-relaxed text-brand-navy-deep/80">{MISION}</p>
      </article>

      <article class="reveal reveal--from-right relative overflow-hidden rounded-sm bg-brand-navy-deep bg-pitch-lines p-7 text-brand-cream shadow-xl shadow-brand-navy/30 md:p-9" style="--idx:1">
        <span class="absolute left-0 top-0 h-full w-1.5 bg-brand-gold" aria-hidden="true"></span>
        <div class="flex items-center gap-3">
          <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-full bg-white/10 text-brand-gold ring-1 ring-brand-gold/30">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7Z"/><circle cx="12" cy="12" r="3"/>
            </svg>
          </div>
          <div>
            <p class="text-[0.7rem] font-bold uppercase tracking-[0.22em] text-brand-gold">Visión</p>
            <h3 class="font-display text-2xl leading-none tracking-wide text-white">Hacia el 2030</h3>
          </div>
        </div>
        <p class="mt-5 text-[0.95rem] leading-relaxed text-brand-cream/85">{VISION}</p>
      </article>
    </div>

    <!-- Principios -->
    <div class="mt-16">
      <div class="reveal flex items-center gap-3 pb-2" style="--idx:0">
        <span class="section-marker text-base italic text-brand-navy">Principios institucionales</span>
        <span class="inline-block h-px flex-1 bg-brand-navy/15" aria-hidden="true"></span>
        <span class="font-display text-2xl leading-none text-brand-navy/30" aria-hidden="true">10</span>
      </div>
      <div class="mt-6 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
        {PRINCIPIOS.map((p, i) => (
          <article class="reveal rounded-sm border border-brand-navy/8 bg-brand-cream p-5 shadow-sm" style={`--idx:${i}`}>
            <div class="flex items-start gap-3">
              <span class="font-display text-3xl leading-none text-brand-navy/20">{p.n}</span>
              <div>
                <h3 class="font-display text-lg leading-tight text-brand-navy-deep">{p.titulo}</h3>
                <p class="mt-2 text-sm leading-relaxed text-neutral-600">{p.descripcion}</p>
              </div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </div>
</section>
