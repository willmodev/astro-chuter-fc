---
/**
 * HeroBallBg — pelota de fútbol SVG decorativa rotando lento al fondo.
 * No interactiva, transform compositor only.
 */
---
<svg
    class="hero-ball-spin pointer-events-none absolute -bottom-24 -right-16 h-72 w-72 text-brand-gold/15 md:-right-10 md:h-96 md:w-96 lg:right-20 lg:bottom-12 lg:h-[420px] lg:w-[420px]"
    viewBox="0 0 100 100"
    aria-hidden="true"
    fill="none"
>
    <circle cx="50" cy="50" r="46" stroke="currentColor" stroke-width="1.2" />
    <!-- Pentágono central clásico -->
    <path
        d="M50 32 L65.6 43.3 L59.6 61.5 L40.4 61.5 L34.4 43.3 Z"
        stroke="currentColor"
        stroke-width="1.1"
        fill="none"
    />
    <!-- Líneas radiantes a las puntas del pentágono -->
    <line x1="50" y1="32" x2="50" y2="6" stroke="currentColor" stroke-width="1" />
    <line x1="65.6" y1="43.3" x2="89" y2="32" stroke="currentColor" stroke-width="1" />
    <line x1="59.6" y1="61.5" x2="78" y2="82" stroke="currentColor" stroke-width="1" />
    <line x1="40.4" y1="61.5" x2="22" y2="82" stroke="currentColor" stroke-width="1" />
    <line x1="34.4" y1="43.3" x2="11" y2="32" stroke="currentColor" stroke-width="1" />
</svg>
