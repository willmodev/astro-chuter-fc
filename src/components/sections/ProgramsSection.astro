---
import { getCollection } from 'astro:content';
import Section from '@/components/layout/Section.astro';
import Container from '@/components/layout/Container.astro';
import SectionHeading from '@/components/layout/SectionHeading.astro';
import ProgramCard from '@/components/sections/ProgramCard.astro';

const programas = (await getCollection('programas')).sort(
  (a, b) => a.data.orden - b.data.orden,
);
---

<Section id="programas" variant="cream-grain">
  <Container>
    <div class="grid items-end gap-8 md:grid-cols-[1fr_auto] md:gap-16">
      <SectionHeading
        align="left"
        numero="01"
        eyebrow="Categorías por año de nacimiento"
        title="Cuatro categorías, una misma cancha."
        subtitle="Cada niño y niña en la categoría que le corresponde según su año de nacimiento, con metodología adaptada a su etapa de desarrollo."
      />
      <p class="hidden font-serif italic text-sm text-brand-navy/70 md:block md:max-w-xs md:text-right" style="font-variation-settings: 'opsz' 144, 'SOFT' 30, 'wght' 400;">
        «Nada de improvisar — formamos por edad, con un plan que crece con el chico.»
      </p>
    </div>

    <div class="mt-12 grid gap-5 sm:grid-cols-2 lg:grid-cols-6">
      {programas.map((programa, index) => (
        <ProgramCard
          nombre={programa.data.nombre}
          nacidos={programa.data.nacidos}
          edadAprox={programa.data.edadAprox}
          horario={programa.data.horario}
          descripcion={programa.data.descripcion}
          entrenador={programa.data.entrenador}
          icono={programa.data.icono}
          color={programa.data.color}
          numero={String(index + 1).padStart(2, '0')}
          idx={index}
          class={index < 2 ? 'lg:col-span-3' : 'lg:col-span-3'}
        />
      ))}
    </div>

    <script>
      // Tilt 3D cursor-driven para cards de programas — solo desktop con mouse fino.
      const supportsHover = matchMedia('(hover: hover) and (pointer: fine)').matches;
      const reduced = matchMedia('(prefers-reduced-motion: reduce)').matches;

      if (supportsHover && !reduced) {
        const cards = document.querySelectorAll<HTMLElement>('[data-tilt]');
        cards.forEach((card) => {
          let frame = 0;
          card.addEventListener(
            'pointermove',
            (e) => {
              if (frame) return;
              frame = requestAnimationFrame(() => {
                const r = card.getBoundingClientRect();
                const mx = (e.clientX - r.left) / r.width - 0.5;
                const my = (e.clientY - r.top) / r.height - 0.5;
                card.style.setProperty('--mx', String(mx));
                card.style.setProperty('--my', String(my));
                frame = 0;
              });
            },
            { passive: true },
          );
          card.addEventListener('pointerleave', () => {
            card.style.setProperty('--mx', '0');
            card.style.setProperty('--my', '0');
          });
        });
      }
    </script>

    <div class="mt-10 flex items-center justify-center gap-3">
      <span class="h-px flex-1 max-w-[80px] bg-brand-navy/15" aria-hidden="true"></span>
      <p class="text-center text-sm text-brand-navy-deep/70">
        ¿No sabés en qué categoría entra tu hijo o hija?{' '}
        <a
          href="https://wa.me/573015216830?text=Hola%20Chuter%20FC%2C%20quiero%20saber%20en%20qué%20categoría%20va%20mi%20hijo"
          target="_blank"
          rel="noopener noreferrer"
          class="font-semibold text-brand-navy-deep underline-offset-4 hover:underline focus-visible:outline-2 focus-visible:outline-brand-gold"
        >
          Consultanos por WhatsApp →
        </a>
      </p>
      <span class="h-px flex-1 max-w-[80px] bg-brand-navy/15" aria-hidden="true"></span>
    </div>
  </Container>
</Section>
