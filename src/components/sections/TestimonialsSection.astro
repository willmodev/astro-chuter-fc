---
import { getCollection } from 'astro:content';
import Section from '@/components/layout/Section.astro';
import Container from '@/components/layout/Container.astro';
import SectionHeading from '@/components/layout/SectionHeading.astro';

const testimonios = (await getCollection('testimonios')).sort(
  (a, b) => a.data.orden - b.data.orden,
);

// Duplicamos la lista para que el loop CSS sea infinito sin saltos
const testimoniosLoop = [...testimonios, ...testimonios];
---

<Section id="testimonios" variant="navy" class="overflow-hidden">
  <!-- Quote mark gigante decorativa -->
  <span class="pointer-events-none absolute -left-8 top-8 select-none font-serif text-[16rem] leading-none text-brand-gold/10 md:text-[22rem]" aria-hidden="true" style="font-variation-settings: 'opsz' 144, 'wght' 700;">
    «
  </span>

  <Container>
    <SectionHeading
      align="center"
      numero="05"
      eyebrow="Lo que dicen los papás"
      title="Familias que ya hacen parte del barrio."
      subtitle="La confianza de las familias es el mayor logro del club."
      light
    />
  </Container>

  <div class="testimonials-marquee mt-12 md:mt-16">
    <div class="testimonials-track">
      {testimoniosLoop.map((t, i) => (
        <article
          class="testimonial-card relative flex shrink-0 flex-col gap-3 rounded-sm border border-brand-cream/10 bg-brand-cream p-6 shadow-xl will-change-transform"
          aria-hidden={i >= testimonios.length}
        >
          <!-- Quote mark pequeño esquina superior -->
          <span class="absolute -top-3 left-5 font-serif text-5xl leading-none text-brand-clay" aria-hidden="true" style="font-variation-settings: 'opsz' 144, 'wght' 700;">
            "
          </span>

          <div class="flex items-center gap-1 pt-2" aria-label="5 estrellas">
            {Array.from({ length: 5 }).map(() => (
              <svg
                aria-hidden="true"
                width="14"
                height="14"
                viewBox="0 0 24 24"
                fill="#C44B2C"
                class="shrink-0"
              >
                <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" />
              </svg>
            ))}
          </div>

          <p class="flex-1 font-serif text-[0.95rem] leading-snug text-brand-navy-deep" style="font-variation-settings: 'opsz' 144, 'SOFT' 30, 'wght' 400;">
            {t.data.texto}
          </p>

          <footer class="border-t border-dashed border-brand-navy/20 pt-3">
            <p class="font-display text-base text-brand-navy-deep">{t.data.autor}</p>
            <p class="text-[0.7rem] uppercase tracking-wider text-brand-navy/55">{t.data.relacion}</p>
          </footer>
        </article>
      ))}
    </div>
  </div>
</Section>

<style>
  .testimonials-marquee {
    position: relative;
    width: 100%;
    overflow: hidden;
    -webkit-mask-image: linear-gradient(
      to right,
      transparent 0,
      black 6%,
      black 94%,
      transparent 100%
    );
    mask-image: linear-gradient(
      to right,
      transparent 0,
      black 6%,
      black 94%,
      transparent 100%
    );
  }

  .testimonials-track {
    display: flex;
    gap: 1.5rem;
    width: max-content;
    padding: 0.5rem 0.75rem;
    animation: testimonials-scroll 70s linear infinite;
  }

  .testimonials-marquee:hover .testimonials-track,
  .testimonials-marquee:focus-within .testimonials-track {
    animation-play-state: paused;
  }

  .testimonial-card {
    width: 320px;
    min-height: 220px;
  }

  @keyframes testimonials-scroll {
    from {
      transform: translateX(0);
    }
    to {
      /* Movemos -50% porque la lista está duplicada */
      transform: translateX(-50%);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .testimonials-track {
      animation: none;
      flex-wrap: wrap;
      justify-content: center;
      width: 100%;
      max-width: 80rem;
      margin: 0 auto;
      padding: 0.5rem 1rem;
    }
    .testimonials-marquee {
      mask-image: none;
      -webkit-mask-image: none;
    }
  }
</style>
