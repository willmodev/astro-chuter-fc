---
import { getCollection } from 'astro:content';
import Section from '@/components/layout/Section.astro';
import Container from '@/components/layout/Container.astro';
import SectionHeading from '@/components/layout/SectionHeading.astro';

const testimonios = (await getCollection('testimonios')).sort(
  (a, b) => a.data.orden - b.data.orden,
);

// Duplicamos la lista para que el loop CSS sea infinito sin saltos
const testimoniosLoop = [...testimonios, ...testimonios];
---

<Section id="testimonios" variant="navy">
  <Container>
    <SectionHeading
      eyebrow="Lo que dicen los papás"
      title="Testimonios"
      subtitle="La confianza de las familias es nuestro mayor logro."
      light
    />
  </Container>

  <div class="testimonials-marquee mt-10 md:mt-14">
    <div class="testimonials-track">
      {testimoniosLoop.map((t, i) => (
        <article
          class="testimonial-card flex shrink-0 flex-col gap-4 rounded-2xl bg-white p-6 shadow-lg ring-1 ring-white/5"
          aria-hidden={i >= testimonios.length}
        >
          <div class="flex gap-1" aria-label="5 estrellas">
            {Array.from({ length: 5 }).map(() => (
              <svg
                aria-hidden="true"
                width="16"
                height="16"
                viewBox="0 0 24 24"
                fill="#F5C842"
                class="shrink-0"
              >
                <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" />
              </svg>
            ))}
          </div>

          <p class="flex-1 text-sm leading-relaxed text-neutral-700">
            "{t.data.texto}"
          </p>

          <footer class="mt-auto border-t border-neutral-100 pt-4">
            <p class="text-sm font-semibold text-brand-navy">{t.data.autor}</p>
            <p class="text-xs text-neutral-500">{t.data.relacion}</p>
          </footer>
        </article>
      ))}
    </div>
  </div>
</Section>

<style>
  .testimonials-marquee {
    position: relative;
    width: 100%;
    overflow: hidden;
    -webkit-mask-image: linear-gradient(
      to right,
      transparent 0,
      black 6%,
      black 94%,
      transparent 100%
    );
    mask-image: linear-gradient(
      to right,
      transparent 0,
      black 6%,
      black 94%,
      transparent 100%
    );
  }

  .testimonials-track {
    display: flex;
    gap: 1.5rem;
    width: max-content;
    padding: 0.5rem 0.75rem;
    animation: testimonials-scroll 70s linear infinite;
  }

  .testimonials-marquee:hover .testimonials-track,
  .testimonials-marquee:focus-within .testimonials-track {
    animation-play-state: paused;
  }

  .testimonial-card {
    width: 320px;
    min-height: 220px;
  }

  @keyframes testimonials-scroll {
    from {
      transform: translateX(0);
    }
    to {
      /* Movemos -50% porque la lista está duplicada */
      transform: translateX(-50%);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .testimonials-track {
      animation: none;
      flex-wrap: wrap;
      justify-content: center;
      width: 100%;
      max-width: 80rem;
      margin: 0 auto;
      padding: 0.5rem 1rem;
    }
    .testimonials-marquee {
      mask-image: none;
      -webkit-mask-image: none;
    }
  }
</style>
