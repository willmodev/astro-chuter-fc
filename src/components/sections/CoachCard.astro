---
interface Props {
  nombre: string;
  rol: string;
  bio: string;
  foto: string;
  instagram?: string;
  numero?: string;
}

const { nombre, rol, bio, foto, instagram, numero } = Astro.props;
const esPlaceholder = bio.startsWith('TODO:');
const igUrl = instagram ? `https://instagram.com/${instagram}` : undefined;
---

<article class="relative grid grid-cols-1 gap-6 rounded-sm border border-brand-navy/10 bg-brand-cream p-6 shadow-sm md:grid-cols-[200px_1fr] md:gap-8 md:p-8">
  <!-- Filigrana número grande -->
  {numero && (
    <span
      class="pointer-events-none absolute -bottom-4 right-6 select-none font-display text-[8rem] leading-none text-brand-navy-deep/[0.04] md:text-[10rem]"
      aria-hidden="true"
    >
      {numero}
    </span>
  )}

  <!-- Foto: rectangular grande con marco editorial -->
  <div class="relative">
    <div class="relative overflow-hidden rounded-sm bg-brand-navy/10 shadow-md md:aspect-[4/5]">
      <div class="aspect-square w-full md:aspect-auto md:h-full">
        {foto ? (
          <img
            src={foto}
            alt={`Foto de ${nombre}`}
            width="320"
            height="400"
            loading="lazy"
            decoding="async"
            class="h-full w-full object-cover"
          />
        ) : (
          <div
            class="flex h-full w-full items-center justify-center bg-brand-navy/5"
            aria-label={`Foto de ${nombre} — próximamente`}
            role="img"
          >
            <svg
              aria-hidden="true"
              width="64"
              height="64"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1"
              class="text-brand-navy/30"
            >
              <circle cx="12" cy="8" r="4" />
              <path d="M4 20c0-4 3.6-7 8-7s8 3 8 7" />
            </svg>
          </div>
        )}
      </div>
      <!-- Tag rotado tipo "FORMADOR" -->
      <div class="absolute bottom-4 left-0 -translate-x-2 rotate-[-4deg] bg-brand-clay px-3 py-1 shadow-md">
        <span class="text-[0.65rem] font-bold uppercase tracking-[0.18em] text-brand-cream">
          Formador
        </span>
      </div>
    </div>
    {igUrl && (
      <a
        href={igUrl}
        target="_blank"
        rel="noopener noreferrer"
        aria-label={`Instagram de ${nombre}`}
        class="absolute -bottom-3 right-3 flex h-10 w-10 items-center justify-center rounded-full bg-gradient-to-br from-purple-500 via-pink-500 to-orange-400 text-white shadow-md transition-transform hover:scale-110 focus-visible:outline-2 focus-visible:outline-brand-gold focus-visible:outline-offset-2"
      >
        <svg aria-hidden="true" width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838a6.162 6.162 0 1 0 0 12.324 6.162 6.162 0 0 0 0-12.324zM12 16a4 4 0 1 1 0-8 4 4 0 0 1 0 8zm6.406-11.845a1.44 1.44 0 1 0 0 2.881 1.44 1.44 0 0 0 0-2.881z" />
        </svg>
      </a>
    )}
  </div>

  <!-- Bio -->
  <div class="relative flex flex-col justify-center space-y-3">
    {numero && (
      <div class="flex items-center gap-3">
        <span class="section-marker text-sm italic text-brand-clay">Nº {numero}</span>
        <span class="h-px flex-1 max-w-[60px] bg-brand-navy/15"></span>
      </div>
    )}
    <h3 class="font-display text-[2.25rem] leading-[0.9] text-brand-navy-deep md:text-[2.75rem]">{nombre}</h3>
    <p class="font-serif text-base italic text-brand-clay" style="font-variation-settings: 'opsz' 144, 'wght' 500;">{rol}</p>
    {esPlaceholder ? (
      <p class="text-sm italic text-neutral-400">
        Bio próximamente — {nombre} comparte su visión del fútbol formativo.
      </p>
    ) : (
      <p class="text-sm leading-relaxed text-brand-navy-deep/75">{bio}</p>
    )}
  </div>
</article>
