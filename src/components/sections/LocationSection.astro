---
import Section from '@/components/layout/Section.astro';
import Container from '@/components/layout/Container.astro';
import SectionHeading from '@/components/layout/SectionHeading.astro';
import StylizedMap from '@/components/sections/StylizedMap.astro';
import { LOCATION, SCHEDULE, CONTACT } from '@/lib/site';

const mapsQuery = encodeURIComponent(`${LOCATION.venue} ${LOCATION.neighborhood}`);
const googleMapsUrl = `https://www.google.com/maps/search/?api=1&query=${mapsQuery}`;
const wazeUrl = `https://www.waze.com/ul?q=${mapsQuery}&navigate=yes`;
---

<Section id="ubicacion" variant="cream-grain">
  <Container>
    <div class="grid items-end gap-6 md:grid-cols-[1fr_auto] md:gap-12">
      <SectionHeading
        align="left"
        numero="06"
        eyebrow="¿Dónde entrenamos?"
        title="La cancha del barrio."
        subtitle={`${LOCATION.venue} · ${LOCATION.neighborhood}`}
      />
      <p class="hidden font-serif italic text-sm text-brand-navy/70 md:block md:max-w-[18rem] md:text-right" style="font-variation-settings: 'opsz' 144, 'wght' 400;">
        «Misma hora, misma cancha. Tres veces a la semana, todo el año.»
      </p>
    </div>

    <div class="mt-12 grid gap-8 lg:grid-cols-[2fr_3fr] lg:items-stretch">
      <div class="relative flex flex-col gap-8 rounded-sm border border-brand-navy/15 bg-white p-6 shadow-sm md:p-8 lg:h-full">
        <!-- Stamp circular -->
        <div class="absolute -right-3 -top-3 flex h-16 w-16 -rotate-12 items-center justify-center rounded-full border-2 border-brand-navy-deep bg-brand-gold shadow-md">
          <span class="section-marker text-[0.6rem] italic leading-tight text-brand-navy-deep text-center px-1">
            cancha<br /><span class="font-display text-base not-italic">oficial</span>
          </span>
        </div>
        <div class="flex flex-col gap-6">
          <div class="flex gap-4">
            <div class="mt-1 flex h-10 w-10 shrink-0 items-center justify-center rounded-xl bg-brand-navy/10 text-brand-navy">
              <svg aria-hidden="true" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" />
              </svg>
            </div>
            <div>
              <p class="text-sm font-semibold text-neutral-700">Cancha</p>
              <p class="text-base text-neutral-600">{LOCATION.venue}</p>
              <p class="text-sm text-neutral-500">{LOCATION.neighborhood}</p>
              <!-- TODO: pedir a Camilo — dirección exacta y link de Google Maps -->
            </div>
          </div>

          <div class="flex gap-4">
            <div class="mt-1 flex h-10 w-10 shrink-0 items-center justify-center rounded-xl bg-brand-navy/10 text-brand-navy">
              <svg aria-hidden="true" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <rect x="3" y="4" width="18" height="18" rx="2" ry="2" />
                <line x1="16" y1="2" x2="16" y2="6" />
                <line x1="8" y1="2" x2="8" y2="6" />
                <line x1="3" y1="10" x2="21" y2="10" />
              </svg>
            </div>
            <div>
              <p class="text-sm font-semibold text-neutral-700">Horarios</p>
              <p class="text-base text-neutral-600">{SCHEDULE.daysHuman}</p>
              <p class="text-sm text-neutral-500">{SCHEDULE.hoursHuman}</p>
            </div>
          </div>

          <div class="flex gap-4">
            <div class="mt-1 flex h-10 w-10 shrink-0 items-center justify-center rounded-xl bg-brand-navy/10 text-brand-navy">
              <svg aria-hidden="true" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
              </svg>
            </div>
            <div>
              <p class="text-sm font-semibold text-neutral-700">Contacto</p>
              <a
                href={`tel:${CONTACT.phoneE164}`}
                class="text-base text-brand-navy hover:underline focus-visible:outline-2 focus-visible:outline-brand-gold"
              >
                {CONTACT.phoneDisplay}
              </a>
              <p class="text-xs text-neutral-500 mt-0.5">WhatsApp disponible</p>
            </div>
          </div>
        </div>

        <div class="mt-auto grid grid-cols-1 gap-3 border-t border-brand-navy/10 pt-6 sm:grid-cols-2">
          <a
            href={googleMapsUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center justify-center gap-2 rounded-xl border border-brand-navy/15 bg-white px-4 py-3 text-sm font-semibold text-brand-navy shadow-sm transition-all hover:border-brand-navy/30 hover:bg-neutral-50 focus-visible:outline-2 focus-visible:outline-brand-gold focus-visible:outline-offset-2"
          >
            <svg aria-hidden="true" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7" />
            </svg>
            <span>Abrir en Google Maps</span>
          </a>
          <a
            href={wazeUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center justify-center gap-2 rounded-xl border border-brand-navy/15 bg-white px-4 py-3 text-sm font-semibold text-brand-navy shadow-sm transition-all hover:border-brand-navy/30 hover:bg-neutral-50 focus-visible:outline-2 focus-visible:outline-brand-gold focus-visible:outline-offset-2"
          >
            <svg aria-hidden="true" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            <span>Abrir en Waze</span>
          </a>
        </div>
      </div>

      <StylizedMap />
    </div>
  </Container>
</Section>
