---
import { Baby, Footprints, Target, Trophy, Medal, Calendar, ArrowRight } from 'lucide-astro';
import { waCategory } from '@/lib/whatsapp';

interface Props {
  nombre: string;
  nacidos: string;
  edadAprox: string;
  horario: string;
  descripcion: string;
  icono: string;
  color: 'navy' | 'blue' | 'gold';
}

const { nombre, nacidos, edadAprox, horario, descripcion, color, icono } = Astro.props;

const colorMap: Record<string, { icon: string; badge: string; title: string }> = {
  navy: {
    icon: 'bg-brand-navy/10 text-brand-navy',
    badge: 'bg-brand-navy/10 text-brand-navy',
    title: 'text-brand-navy',
  },
  blue: {
    icon: 'bg-brand-blue/10 text-brand-blue',
    badge: 'bg-brand-blue/10 text-brand-blue',
    title: 'text-brand-blue',
  },
  gold: {
    icon: 'bg-brand-gold/20 text-brand-gold-deep',
    badge: 'bg-brand-gold/20 text-brand-gold-deep',
    title: 'text-brand-gold-deep',
  },
};

const c = colorMap[color];
const waLink = waCategory(nombre);

const iconMap = { Baby, Footprints, Target, Trophy, Medal };
const Icon = iconMap[icono as keyof typeof iconMap] ?? Trophy;
---

<article
  class="group flex flex-col rounded-2xl border border-neutral-200 bg-white p-6 shadow-sm transition-all duration-200 hover:-translate-y-1 hover:shadow-xl md:p-8"
>
  <div class={`flex h-14 w-14 items-center justify-center rounded-2xl ${c.icon}`}>
    <Icon size={28} strokeWidth={1.75} aria-hidden="true" />
  </div>

  <span
    class={`mt-4 inline-flex w-fit items-center whitespace-nowrap rounded-full px-2.5 py-1 text-xs font-semibold ${c.badge}`}
  >
    Nacidos {nacidos}
  </span>

  <h3 class={`mt-3 font-display text-h3 ${c.title}`}>{nombre}</h3>
  <p class="mt-0.5 text-xs text-neutral-500">{edadAprox}</p>
  <p class="mt-3 flex-1 text-sm leading-relaxed text-neutral-600">{descripcion}</p>

  <div class="mt-4 flex items-center gap-1.5 text-xs text-neutral-500">
    <Calendar size={14} strokeWidth={1.5} aria-hidden="true" class="shrink-0" />
    <span>{horario}</span>
  </div>

  <a
    href={waLink}
    target="_blank"
    rel="noopener noreferrer"
    aria-label={`Inscribir a mi hijo en la categoría ${nombre} vía WhatsApp`}
    class="mt-5 flex items-center justify-center gap-1.5 rounded-full border-2 border-brand-navy px-3 py-2.5 text-sm font-semibold text-brand-navy transition-colors duration-150 hover:bg-brand-navy hover:text-white focus-visible:outline-2 focus-visible:outline-brand-gold focus-visible:outline-offset-2"
  >
    Inscribirme
    <ArrowRight size={14} strokeWidth={2} aria-hidden="true" />
  </a>
</article>
