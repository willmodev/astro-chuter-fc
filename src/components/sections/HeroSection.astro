---
import { Image } from 'astro:assets';
import heroImg from '@/assets/images/hero.jpg';
import BrandButton from '@/components/layout/BrandButton.astro';
import { WA_HERO } from '@/lib/whatsapp';
import { SCHEDULE } from '@/lib/site';
---

<section
  id="inicio"
  class="relative isolate flex min-h-[88vh] items-center overflow-hidden bg-brand-navy-deep"
  aria-label="Sección principal de Chuter FC"
>
  <Image
    src={heroImg}
    alt="Entrenamiento de niños en Chuter FC — Cancha de la Provincia, Los Algarrobillos"
    class="absolute inset-0 h-full w-full object-cover object-[20%_center]"
    widths={[640, 960, 1440]}
    sizes="100vw"
    loading="eager"
    fetchpriority="high"
    quality={85}
  />

  <!-- Overlay base navy -->
  <div class="absolute inset-0 bg-gradient-to-r from-brand-navy-deep/95 via-brand-navy-deep/85 to-brand-navy/75"></div>
  <!-- Bloom dorado sutil esquina sup-izq -->
  <div class="pointer-events-none absolute -left-24 -top-24 h-[480px] w-[480px] rounded-full bg-brand-gold/15 blur-3xl"></div>
  <!-- Grain overlay -->
  <div class="pointer-events-none absolute inset-0 bg-grain opacity-60 mix-blend-overlay"></div>

  <!-- Cinta diagonal vertical lateral derecha (decorativa) -->
  <div class="pointer-events-none absolute right-0 top-0 hidden h-full w-24 lg:block">
    <div class="h-full w-full diagonal-stripes text-brand-gold/10"></div>
  </div>

  <!-- Marker editorial vertical "Nº 00 · Inicio" -->
  <div class="pointer-events-none absolute left-6 top-1/2 hidden -translate-y-1/2 -rotate-90 origin-left lg:block">
    <span class="section-marker text-sm text-white/40">Nº 00 · Inicio</span>
  </div>

  <div class="relative z-10 mx-auto grid w-full max-w-7xl gap-10 px-4 py-20 md:px-6 lg:grid-cols-[1.5fr_1fr] lg:gap-16 lg:px-12 lg:py-24">
    <!-- Columna principal -->
    <div class="space-y-8">
      <!-- Eyebrow editorial: número + label + rule -->
      <div class="flex items-center gap-4">
        <span class="section-marker text-base italic text-brand-gold">Nº 00</span>
        <span class="h-px w-12 bg-brand-gold/50" aria-hidden="true"></span>
        <span class="text-[0.7rem] font-bold uppercase tracking-[0.28em] text-brand-gold">
          Club Deportivo · Los Algarrobillos
        </span>
      </div>

      <!-- Headline mixto display + serif italic -->
      <h1 class="font-display text-[clamp(3rem,8vw,7rem)] leading-[0.88] text-white">
        Formando<br />
        <span class="font-serif italic font-light text-brand-gold" style="font-variation-settings: 'opsz' 144, 'SOFT' 100, 'wght' 300;">campeones</span><br />
        dentro y<br />
        fuera de la<br />
        <span class="relative inline-block">
          cancha
          <svg class="absolute -bottom-2 left-0 w-full" viewBox="0 0 200 12" preserveAspectRatio="none" aria-hidden="true">
            <path d="M2 8 Q 50 2, 100 6 T 198 7" stroke="#F5C842" stroke-width="3" fill="none" stroke-linecap="round" />
          </svg>
        </span>.
      </h1>

      <!-- Sub copy y horario -->
      <div class="max-w-xl space-y-2">
        <p class="text-base leading-relaxed text-white/80 md:text-lg">
          Escuela de fútbol formativo para niños y niñas en Los Algarrobillos.
          Avalada por <span class="font-semibold text-white">INDER</span>.
        </p>
        <p class="text-sm font-semibold uppercase tracking-wider text-brand-gold">
          {SCHEDULE.daysHuman} — {SCHEDULE.hoursHuman}
        </p>
      </div>

      <!-- CTAs -->
      <div class="flex flex-col gap-3 sm:flex-row sm:items-center">
        <BrandButton
          href={WA_HERO}
          variant="cta-gold"
          size="lg"
          target="_blank"
          ariaLabel="Inscribirse gratis en Chuter FC vía WhatsApp"
        >
          ¡Quiero inscribirme gratis!
        </BrandButton>
        <a
          href="#programas"
          class="group inline-flex items-center gap-2 px-2 py-3 text-sm font-semibold uppercase tracking-wider text-white transition-colors hover:text-brand-gold focus-visible:outline-2 focus-visible:outline-brand-gold focus-visible:outline-offset-4"
        >
          Ver programas
          <span aria-hidden="true" class="inline-block transition-transform group-hover:translate-x-1">→</span>
        </a>
      </div>
    </div>

    <!-- Columna lateral: ticket card -->
    <aside class="relative self-end lg:self-center">
      <div class="relative rotate-[1.5deg] overflow-hidden rounded-sm border border-brand-gold/30 bg-brand-cream p-6 shadow-2xl shadow-black/40 md:p-8">
        <!-- Header del ticket -->
        <div class="flex items-baseline justify-between border-b border-dashed border-brand-navy/25 pb-3">
          <span class="font-display text-2xl tracking-wider text-brand-navy-deep">CUPO 2026</span>
          <span class="section-marker text-xs italic text-brand-clay">edición limitada</span>
        </div>

        <!-- Contenido -->
        <div class="mt-4 space-y-3">
          <p class="font-display text-5xl leading-none text-brand-clay">¡GRATIS!</p>
          <p class="font-serif italic text-lg leading-snug text-brand-navy-deep" style="font-variation-settings: 'opsz' 144, 'SOFT' 30, 'wght' 400;">
            La inscripción no te cuesta nada. Solo traer a tu hijo o hija con ganas de jugar.
          </p>
        </div>

        <!-- Stats minis -->
        <dl class="mt-5 grid grid-cols-3 gap-2 border-t border-dashed border-brand-navy/25 pt-4 text-center">
          <div>
            <dt class="text-[0.65rem] uppercase tracking-wider text-brand-navy/60">Categorías</dt>
            <dd class="font-display text-2xl leading-none text-brand-navy-deep">5</dd>
          </div>
          <div class="border-x border-dashed border-brand-navy/25">
            <dt class="text-[0.65rem] uppercase tracking-wider text-brand-navy/60">Edades</dt>
            <dd class="font-display text-2xl leading-none text-brand-navy-deep">5–14</dd>
          </div>
          <div>
            <dt class="text-[0.65rem] uppercase tracking-wider text-brand-navy/60">x Semana</dt>
            <dd class="font-display text-2xl leading-none text-brand-navy-deep">3</dd>
          </div>
        </dl>

        <!-- Stamp circular gold -->
        <div class="absolute -right-4 -top-4 flex h-20 w-20 -rotate-12 items-center justify-center rounded-full border-2 border-brand-navy-deep bg-brand-gold shadow-lg">
          <span class="section-marker text-xs italic leading-none text-brand-navy-deep text-center px-2">
            avalado<br />INDER
          </span>
        </div>

        <!-- Notch lateral (tipo ticket cortado) -->
        <div class="absolute -left-3 top-1/2 h-6 w-6 -translate-y-1/2 rounded-full bg-brand-navy-deep"></div>
        <div class="absolute -right-3 top-1/2 h-6 w-6 -translate-y-1/2 rounded-full bg-brand-navy-deep"></div>
      </div>

      <!-- Sombra/halo dorado detrás -->
      <div class="pointer-events-none absolute -inset-4 -z-10 rounded-md bg-gradient-to-br from-brand-gold/20 to-transparent blur-2xl"></div>
    </aside>
  </div>

  <!-- Strip inferior con "scroll" hint -->
  <div class="absolute bottom-0 left-0 right-0 z-10 border-t border-white/10 bg-brand-navy-deep/60 backdrop-blur-sm">
    <div class="mx-auto flex max-w-7xl items-center justify-between gap-4 px-4 py-3 text-[0.65rem] uppercase tracking-[0.25em] text-white/60 md:px-6 lg:px-12">
      <span class="hidden sm:inline">Cancha de la Provincia · Los Algarrobillos</span>
      <span class="flex items-center gap-2 text-brand-gold">
        Bajá para descubrir
        <span class="inline-block animate-bounce" aria-hidden="true">↓</span>
      </span>
      <span class="hidden text-white/40 sm:inline section-marker italic normal-case tracking-normal">est. 2024</span>
    </div>
  </div>
</section>
