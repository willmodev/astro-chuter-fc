---
import { getCollection } from 'astro:content';
import Section from '@/components/layout/Section.astro';
import Container from '@/components/layout/Container.astro';
import SectionHeading from '@/components/layout/SectionHeading.astro';
import CoachCard from '@/components/sections/CoachCard.astro';

const formadores = (await getCollection('formadores')).sort(
  (a, b) => a.data.orden - b.data.orden,
);
---

<Section id="formadores" variant="cream-grain">
  <Container>
    <SectionHeading
      align="center"
      numero="03"
      eyebrow="El equipo detrás del club"
      title="Profesionales que entienden el barrio."
      subtitle="Comprometidos con el desarrollo integral de cada niño y niña que pasa por la cancha."
    />

    <div class="mx-auto mt-12 grid max-w-5xl gap-8 sm:grid-cols-1 lg:gap-10">
      {formadores.map((formador, index) => (
        <CoachCard
          nombre={formador.data.nombre}
          rol={formador.data.rol}
          bio={formador.data.bio}
          foto={formador.data.foto}
          instagram={formador.data.instagram}
          etiqueta={formador.data.etiqueta}
          numero={String(index + 1).padStart(2, '0')}
        />
      ))}
    </div>
  </Container>
</Section>
