---
import { LOCATION } from '@/lib/site';
---

<div class="stylized-map-container relative aspect-[4/3] overflow-hidden rounded-2xl shadow-xl ring-1 ring-brand-navy/10 sm:aspect-[5/4] lg:aspect-auto lg:h-full lg:min-h-[460px]">
    <svg
      viewBox="0 0 400 400"
      preserveAspectRatio="xMidYMid slice"
      class="absolute inset-0 h-full w-full"
      role="img"
      aria-label={`Mapa estilizado de ${LOCATION.venue} en ${LOCATION.neighborhood}`}
    >
      <defs>
        <linearGradient id="mapBg" x1="0" y1="0" x2="1" y2="1">
          <stop offset="0%" stop-color="#1B3A6B" />
          <stop offset="100%" stop-color="#0F2647" />
        </linearGradient>
        <radialGradient id="spotlight" cx="0.5" cy="0.55" r="0.45">
          <stop offset="0%" stop-color="#F5C842" stop-opacity="0.18" />
          <stop offset="100%" stop-color="#F5C842" stop-opacity="0" />
        </radialGradient>
        <pattern id="grass" x="0" y="0" width="6" height="6" patternUnits="userSpaceOnUse">
          <rect width="6" height="6" fill="#2D6A3E" />
          <circle cx="1" cy="1" r="0.4" fill="#3A8050" />
          <circle cx="4" cy="3" r="0.4" fill="#256334" />
        </pattern>
      </defs>

      <rect width="400" height="400" fill="url(#mapBg)" />
      <rect width="400" height="400" fill="url(#spotlight)" />

      <!-- BLOQUES URBANOS (manzanas) — fondo lejano -->
      <g opacity="0.35">
        <rect x="20" y="30" width="80" height="50" rx="3" fill="#2A4880" />
        <rect x="110" y="20" width="60" height="40" rx="3" fill="#2A4880" />
        <rect x="180" y="35" width="90" height="45" rx="3" fill="#2A4880" />
        <rect x="280" y="25" width="100" height="55" rx="3" fill="#2A4880" />

        <rect x="20" y="320" width="70" height="50" rx="3" fill="#2A4880" />
        <rect x="100" y="335" width="80" height="45" rx="3" fill="#2A4880" />
        <rect x="190" y="325" width="60" height="55" rx="3" fill="#2A4880" />
        <rect x="260" y="320" width="120" height="50" rx="3" fill="#2A4880" />

        <rect x="20" y="160" width="55" height="80" rx="3" fill="#2A4880" />
        <rect x="320" y="170" width="60" height="90" rx="3" fill="#2A4880" />
      </g>

      <!-- CALLES — líneas blancas semitransparentes con curvas -->
      <g stroke="#F1F5F9" stroke-opacity="0.18" fill="none" stroke-linecap="round">
        <!-- horizontales -->
        <path d="M0 100 Q 200 95 400 105" stroke-width="14" />
        <path d="M0 300 Q 200 305 400 295" stroke-width="14" />
        <!-- verticales -->
        <path d="M90 0 Q 95 200 88 400" stroke-width="10" />
        <path d="M310 0 Q 305 200 312 400" stroke-width="10" />
        <!-- diagonal sutil -->
        <path d="M0 0 Q 200 200 400 400" stroke-width="6" stroke-opacity="0.08" />
      </g>

      <!-- Líneas centrales blancas (carriles) -->
      <g stroke="#FBF8EA" stroke-opacity="0.5" stroke-width="0.8" stroke-dasharray="4 4" fill="none">
        <path d="M0 100 Q 200 95 400 105" />
        <path d="M0 300 Q 200 305 400 295" />
        <path d="M90 0 Q 95 200 88 400" />
        <path d="M310 0 Q 305 200 312 400" />
      </g>

      <!-- ÁRBOLES decorativos -->
      <g fill="#3D8456" opacity="0.85">
        <circle cx="50" cy="135" r="4" />
        <circle cx="68" cy="142" r="3.5" />
        <circle cx="345" cy="140" r="4" />
        <circle cx="360" cy="148" r="3.5" />
        <circle cx="48" cy="265" r="4" />
        <circle cx="62" cy="272" r="3.5" />
        <circle cx="350" cy="268" r="4" />
        <circle cx="365" cy="262" r="3.5" />
      </g>

      <!-- LA CANCHA — rectángulo central destacado -->
      <g transform="translate(140 160)">
        <rect width="120" height="80" rx="4" fill="url(#grass)" stroke="#FBF8EA" stroke-width="1.5" />
        <!-- líneas de cancha -->
        <rect x="0" y="0" width="120" height="80" rx="4" fill="none" stroke="#FBF8EA" stroke-width="1.5" />
        <line x1="60" y1="0" x2="60" y2="80" stroke="#FBF8EA" stroke-width="1" />
        <circle cx="60" cy="40" r="10" fill="none" stroke="#FBF8EA" stroke-width="1" />
        <circle cx="60" cy="40" r="1.5" fill="#FBF8EA" />
        <!-- áreas de gol -->
        <rect x="0" y="25" width="14" height="30" fill="none" stroke="#FBF8EA" stroke-width="1" />
        <rect x="106" y="25" width="14" height="30" fill="none" stroke="#FBF8EA" stroke-width="1" />
      </g>

      <!-- PIN — pulse exterior -->
      <g class="map-pin" transform="translate(200 175)">
        <circle r="22" fill="#F5C842" fill-opacity="0.25" class="pin-pulse-outer" />
        <circle r="14" fill="#F5C842" fill-opacity="0.4" class="pin-pulse-inner" />
        <!-- shadow -->
        <ellipse cx="0" cy="32" rx="8" ry="2" fill="#000" fill-opacity="0.3" />
        <!-- pin shape -->
        <path
          d="M0 -28 C -10 -28 -16 -20 -16 -12 C -16 -2 -8 8 0 24 C 8 8 16 -2 16 -12 C 16 -20 10 -28 0 -28 Z"
          fill="#F5C842"
          stroke="#FBF8EA"
          stroke-width="2"
        />
        <circle cx="0" cy="-13" r="6" fill="#FBF8EA" />
        <circle cx="0" cy="-13" r="3.5" fill="#0F2647" />
      </g>
    </svg>

    <!-- Etiqueta glassmorphic de la cancha -->
    <div class="absolute bottom-4 left-4 right-4 sm:left-6 sm:right-6 sm:bottom-6">
      <div class="rounded-2xl border border-white/20 bg-white/10 px-4 py-3 backdrop-blur-md sm:px-5 sm:py-4">
        <div class="flex items-start gap-3">
          <div class="mt-0.5 flex h-9 w-9 shrink-0 items-center justify-center rounded-full bg-brand-gold text-brand-navy-deep">
            <svg aria-hidden="true" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" />
            </svg>
          </div>
          <div class="min-w-0 flex-1">
            <p class="text-base font-bold leading-tight text-white sm:text-lg">{LOCATION.venue}</p>
            <p class="text-xs text-white/70 sm:text-sm">{LOCATION.neighborhood} · Colombia</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  .pin-pulse-outer {
    transform-origin: center;
    transform-box: fill-box;
    animation: pin-pulse 2.4s ease-out infinite;
  }
  .pin-pulse-inner {
    transform-origin: center;
    transform-box: fill-box;
    animation: pin-pulse 2.4s ease-out infinite 0.6s;
  }

  @keyframes pin-pulse {
    0% {
      transform: scale(0.6);
      opacity: 0.7;
    }
    80%,
    100% {
      transform: scale(2.2);
      opacity: 0;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .pin-pulse-outer,
    .pin-pulse-inner {
      animation: none;
      opacity: 0.4;
    }
  }
</style>
